# =============================================================================
# Squant Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All sensitive values (passwords, API keys) should NEVER be committed to git.
#
# Configuration is organized by domain. See src/squant/config.py for details.
# =============================================================================

# =============================================================================
# Application
# =============================================================================
APP_NAME=Squant
APP_ENV=production                    # development | staging | production
DEBUG=false
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5175"]

# =============================================================================
# Database (PostgreSQL + TimescaleDB)
# =============================================================================
# Production uses standard port 5432; dev environment uses 5433 (see .env)
DATABASE_URL=postgresql+asyncpg://squant:your-password@localhost:5432/squant

# =============================================================================
# Redis
# =============================================================================
# Production uses standard port 6379; dev environment uses 6380 (see .env)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-at-least-32-characters-long
ENCRYPTION_KEY=your-32-byte-encryption-key-here!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                       # json | text
# LOG_FILE=logs/app.log              # Optional: log file path (auto-rotated)
# LOG_MAX_BYTES=10485760             # Max log file size before rotation (default: 10MB)
# LOG_BACKUP_COUNT=5                 # Number of rotated files to keep (default: 5)

# =============================================================================
# Exchange Streaming
# =============================================================================
DEFAULT_EXCHANGE=okx                  # okx | binance | bybit

# =============================================================================
# OKX Exchange API
# =============================================================================
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# =============================================================================
# Binance Exchange API
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# =============================================================================
# Bybit Exchange API
# =============================================================================
BYBIT_API_KEY=
BYBIT_API_SECRET=

# =============================================================================
# Strategy Engine
# =============================================================================
STRATEGY_MAX_PROCESSES=5              # Max concurrent strategy processes
STRATEGY_MEMORY_LIMIT_MB=512          # Memory limit per strategy
STRATEGY_CPU_LIMIT_SECONDS=60         # CPU time limit per execution
STRATEGY_SANDBOX_ENABLED=true         # Enable RestrictedPython sandbox
STRATEGY_MAX_BAR_HISTORY=1000         # Max bars in strategy history (100-50000, 1m needs ~1500 for 24h)

# =============================================================================
# Risk Control
# =============================================================================
RISK_MAX_POSITION_RATIO=0.3           # Max position as ratio of portfolio (0.3 = 30%)
RISK_MAX_DAILY_LOSS_RATIO=0.05        # Max daily loss ratio (0.05 = 5%)
RISK_MAX_ORDERS_PER_MINUTE=10         # Rate limit: orders per minute

# =============================================================================
# Paper Trading
# =============================================================================
PAPER_MAX_EQUITY_CURVE_SIZE=10000     # Max equity curve data points
PAPER_MAX_COMPLETED_ORDERS=1000       # Max completed orders to keep
PAPER_MAX_FILLS=5000                  # Max order fills to keep
PAPER_MAX_TRADES=1000                 # Max trades to keep
PAPER_MAX_LOGS=1000                   # Max strategy logs to keep
PAPER_HEALTH_CHECK_INTERVAL_SECONDS=60
PAPER_SESSION_TIMEOUT_SECONDS=300     # 5 minutes = stale session
PAPER_PERSIST_INTERVAL_SECONDS=60     # Auto-persist interval

# =============================================================================
# Circuit Breaker
# =============================================================================
CIRCUIT_BREAKER_COOLDOWN_MINUTES=60   # Cooldown after trigger
CIRCUIT_BREAKER_AUTO_ENABLED=false    # Auto-trigger on risk events

# =============================================================================
# Notifications
# =============================================================================
NOTIFICATION_ENABLED=true
NOTIFICATION_WEBHOOK_URL=                   # HTTP POST URL for alerts (empty = disabled)
NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=10     # Webhook request timeout
NOTIFICATION_WEBHOOK_MAX_RETRIES=3          # Retry attempts for failed webhooks
NOTIFICATION_COOLDOWN_SECONDS=60            # Dedup window for same event type
NOTIFICATION_MAX_HISTORY=1000               # Max notification records to keep
