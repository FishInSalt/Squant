# ============ Local Test Environment Template ============
# Copy this file to .env.test.local and fill in actual values:
#   cp .env.test.local.example .env.test.local
#
# This file is for DevContainer/local testing
# Uses Docker service names for database and Redis

APP_NAME=Squant
APP_ENV=test
DEBUG=true
SECRET_KEY=test-secret-key-for-integration-testing-min-32-chars
API_PREFIX=/api/v1

# ============ Database (Docker service name) ============
# DevContainer: postgres:5432 (Docker internal network)
DB_USER=squant
DB_PASSWORD=devpassword
DB_NAME=squant_test
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://squant:devpassword@postgres:5432/squant_test

# ============ Redis (Docker service name) ============
# DevContainer: redis:6379 (Docker internal network)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_URL=redis://redis:6379/1

# ============ Security ============
ENCRYPTION_KEY=cTYK1ELdwLfxoLdD6z2YqraA0vasUEED

# ============ CORS ============
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============ Logging ============
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============ Exchange Credentials ============
# Fill in your testnet API credentials for local integration tests
# These are sensitive - this file should NOT be committed to git
DEFAULT_EXCHANGE=okx
USE_CCXT_PROVIDER=true
OKX_TESTNET=true
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
