# ============ CI Test Environment ============
# This file is for GitHub Actions CI environment ONLY
# Uses localhost addresses with port mapping
# Exchange credentials are empty - related tests are skipped in CI

APP_NAME=Squant
APP_ENV=test
DEBUG=true
SECRET_KEY=test-secret-key-for-integration-testing-min-32-chars
API_PREFIX=/api/v1

# ============ Database (CI uses port mapping) ============
# CI service: postgres container mapped to localhost:5433
DB_USER=squant_test
DB_PASSWORD=squant_test
DB_NAME=squant_test
DB_HOST=localhost
DB_PORT=5433
DATABASE_URL=postgresql+asyncpg://squant_test:squant_test@localhost:5433/squant_test

# ============ Redis (CI uses port mapping) ============
# CI service: redis container mapped to localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=1
REDIS_URL=redis://localhost:6380/1

# ============ Security ============
ENCRYPTION_KEY=cTYK1ELdwLfxoLdD6z2YqraA0vasUEED

# ============ CORS ============
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============ Logging ============
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============ Exchange Streaming ============
DEFAULT_EXCHANGE=okx
USE_CCXT_PROVIDER=true

# ============ OKX ============
# Empty in CI - tests requiring API credentials are skipped
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true
