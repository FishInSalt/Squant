# ============ Test Environment ============
APP_NAME=Squant
APP_ENV=development
DEBUG=true
SECRET_KEY=test-secret-key-for-integration-testing-min-32-chars
API_PREFIX=/api/v1

# ============ Database (test database in dev container) ============
DB_USER=squant
DB_PASSWORD=devpassword
DB_NAME=squant_test
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://squant:devpassword@postgres:5432/squant_test

# ============ Redis (test database in dev container) ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_URL=redis://redis:6379/1

# ============ Security ============
ENCRYPTION_KEY=cTYK1ELdwLfxoLdD6z2YqraA0vasUEED

# ============ CORS ============
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============ Logging ============
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============ Exchange Streaming ============
DEFAULT_EXCHANGE=okx
USE_CCXT_PROVIDER=true

# ============ OKX ============
# Note: Real credentials should be in .env (not committed to git)
# These are placeholders for CI - private tests are skipped in CI
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true
