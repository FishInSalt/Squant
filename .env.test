# ============ Test Environment ============
# 使用 localhost 和映射端口，兼容 CI 和本地测试（通过端口映射）
APP_NAME=Squant
APP_ENV=test
DEBUG=true
SECRET_KEY=test-secret-key-for-integration-testing-min-32-chars
API_PREFIX=/api/v1

# ============ Database (test database) ============
# CI: localhost:5433 (GitHub Actions service)
# Local: localhost:5433 -> postgres:5432 (port mapping)
DB_USER=squant_test
DB_PASSWORD=squant_test
DB_NAME=squant_test
DB_HOST=localhost
DB_PORT=5433
DATABASE_URL=postgresql+asyncpg://squant_test:squant_test@localhost:5433/squant_test

# ============ Redis (test database) ============
# CI: localhost:6380 (GitHub Actions service)
# Local: localhost:6380 -> redis:6379 (port mapping)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=1
REDIS_URL=redis://localhost:6380/1

# ============ Security ============
ENCRYPTION_KEY=cTYK1ELdwLfxoLdD6z2YqraA0vasUEED

# ============ CORS ============
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============ Logging ============
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============ Exchange Streaming ============
DEFAULT_EXCHANGE=okx
USE_CCXT_PROVIDER=true

# ============ OKX ============
# Note: Real credentials should be in .env (not committed to git)
# These are placeholders for CI - private tests are skipped in CI
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true
