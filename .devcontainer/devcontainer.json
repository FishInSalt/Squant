{
  "name": "Squant Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/Squant",
  "shutdownAction": "none",

  // Port forwarding
  "forwardPorts": [8000, 5175, 5433, 6380],
  "portsAttributes": {
    "8000": { "label": "Backend API", "onAutoForward": "notify" },
    "5175": { "label": "Frontend Dev", "onAutoForward": "openBrowser" },
    "5433": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "6380": { "label": "Redis", "onAutoForward": "silent" }
  },

  // Run after container is created
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // VS Code customizations
  "customizations": {
    "vscode": {
      "settings": {
        // Python
        "python.defaultInterpreterPath": "/workspaces/Squant/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "ruff.path": ["/workspaces/Squant/.venv/bin/ruff"],

        // TypeScript/Vue
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[vue]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },

        // Files
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/*.pyc": true
        },

        // Terminal
        "terminal.integrated.defaultProfile.linux": "bash",

        // Database
        "sqltools.connections": [
          {
            "name": "Squant Dev",
            "driver": "PostgreSQL",
            "server": "postgres",
            "port": 5432,
            "database": "squant",
            "username": "squant",
            "password": "devpassword"
          }
        ]
      },

      "extensions": [
        // Python
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",

        // Vue / TypeScript
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // Database
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "cweijan.vscode-redis-client",

        // DevOps
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",

        // Utilities
        "usernamehw.errorlens",
        "gruntfuggly.todo-tree",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },

  // User settings
  "remoteUser": "vscode",

  // Mounts for better performance
  "mounts": [
    // Use named volume for uv cache
    "source=squant-uv-cache,target=/home/vscode/.cache/uv,type=volume"
  ]
}
