{
    email {$ACME_EMAIL:admin@example.com}
}

# 本地开发使用 localhost
localhost {
    # API 代理
    handle /api/* {
        reverse_proxy backend:8000
    }

    # WebSocket 代理
    handle /ws/* {
        reverse_proxy backend:8000
    }

    # 前端静态文件
    handle {
        reverse_proxy frontend:80
    }
}

# 生产环境使用实际域名
